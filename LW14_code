#include <iostream>
#include <cstdlib>
#include <iomanip>
using namespace std;
int main()
{
    //Task 1
    int pos_count, neg_count;
    srand(time(NULL));
    float *arr = new float [12];
    cout << "Generated array: { ";
    for (int i = 0; i < 12; i++) {
        float divide = rand() % 25 - 4;
        arr[i] = (rand() % 5 - 2) / divide;
        if (divide != 0 && arr[i] != -0 && arr[i] > -2 && arr[i] < 2) {
            cout << setprecision(3) << arr[i] << " ";
        }
        else {
            i--;
        }
    }
    cout << "}" << endl;
    pos_count = 0;
    neg_count = 0;
    for (int cnt = 0; cnt < 12; cnt++) {
        if (arr[cnt] > 0) {
            pos_count += 1;
        }
        if (arr[cnt] < 0) {
            neg_count += 1;
        }
    }
    cout << "The amount of positive array elements: " << pos_count << endl << "The amount of negative array elements: " << neg_count;
    delete [] arr;
    return 0;
    
    //Task 2
    int ev_count, unev_count;
    srand(time(NULL));
    
    float **mas = new float* [4];
    for (int col = 0; col < 4; col++) {
        mas[col] = new float [4];
    }
    
    cout << "Generated two-dimension array: " << endl;
    for (int i = 0; i < 4; i++) {
        for (int j = 0; j < 4; j++) {
            float dif = rand() % 21 - 10;
            mas[i][j] = (rand() % 21 - 10) / dif;
            
            if (dif != 0 && mas[i][j] != -0) {
                cout << setw(6) << setprecision(3) << mas[i][j] << " ";
            }
            else {
                j--;
            }
        }
        cout << endl;
    }
    cout << endl;
    
    cout << "Main diagonal elements: { ";
    for (int a = 0; a < 4; a++) {
        for (int b = 0; b < 4; b++) {
            if (a == b) {
                cout << mas[a][b] << " ";
            }
        }
    }
    cout << "}" << endl;
    
    cout << "Side diagonal elements: { ";
    for (int a = 0; a < 4; a++) {
        for (int b = 0; b < 4; b++) {
            if (a + b == 3) {
                cout << mas[a][b] << " ";
            }
        }
    }
    cout << "}" << endl;
    
    ev_count = 0;
    unev_count = 0;
    
    for (int m = 0; m < 4; m++) {
        for (int n = 0; n < 4; n++) {
            if ((int)mas[m][n] % 2 == 0) {
                ev_count += 1;
            }
            if ((int)mas[m][n] % 2 != 0) {
                unev_count += 1;
            }
        }
    }
    
    cout << "The amount of even elements: " << ev_count << endl;
    cout << "The amount of uneven elements: " << unev_count;
    
    for (int col = 0; col < 4; col++) {
        delete [] mas [col];
        return 0;
    }
}
